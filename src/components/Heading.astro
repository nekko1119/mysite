---
interface Props {
  class?: string;
  level: "1" | "2";
}

const { level, class: className } = Astro.props;
---

{
  level === "1" && (
    <h1 class={`font-bold text-2xl sm:text-3xl my-4 ${className}`}>
      <slot />
    </h1>
  )
}
{
  level === "2" && (
    <h2 class={`font-bold text-xl sm:text-2xl my-3 ${className}`}>
      <slot />
    </h2>
  )
}
