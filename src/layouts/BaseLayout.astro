---
import "@styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Icon } from "astro-icon/components";

interface Props {
  isContent?: boolean;
}
const { isContent = false } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href={new URL("favicon.ico", Astro.url).pathname} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>nekko1119.org</title>
    <meta property="og:title" content="nekko1119" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="http://nekko1119.github.io/mysite" />
    <meta property="og:description" content="nekko1119のウェブサイト" />
    <ClientRouter />
  </head>
  <body transition:animate="slide" class="py-4">
    <main
      class={isContent ? "mx-auto w-full max-w-2xl px-4 2xl:px-0" : undefined}
    >
      {
        isContent && (
          <a
            href={
              // eslint-disable-next-line @typescript-eslint/no-unsafe-assignment, @typescript-eslint/no-unsafe-member-access  -- 型がついているのに型が認識できてなさそう
              import.meta.env.BASE_URL
            }
            class="link themed-link inline-flex items-center"
          >
            <Icon name="lucide:arrow-left" />
            戻る
          </a>
        )
      }
      <slot />
    </main>
  </body>
</html>
