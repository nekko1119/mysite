{
  "name": "mysite",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0 --report-unused-disable-directives",
    "prepare": "husky",
    "type-check": "astro check",
    "test": "playwright test --grep-invert @vrt",
